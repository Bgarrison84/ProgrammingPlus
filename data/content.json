  "projects": [
    {
      "id": "py_p7",
      "track": "python",
      "title": "NeuroNPC",
      "icon": "🧠",
      "difficulty": "mythic",
      "xp": 12000,
      "minLevel": 6,
      "description": "Neural Network implementation.",
      "briefing": "Create a backpropagation network from scratch.",
      "phases": [
        {
          "id": "p1",
          "type": "code",
          "title": "The Neuron Class",
          "xp": 4000,
          "filename": "neuron.py",
          "description": "Create a fundamental Neuron with weights and sigmoid activation.",
          "starter_code": "import math\n\nclass Neuron:\n    def __init__(self, n_inputs):\n        self.weights = [0.1] * n_inputs\n        self.bias = 0.0\n",
          "solution": "import math\n\nclass Neuron:\n    def __init__(self, n_inputs):\n        self.weights = [0.1] * n_inputs\n        self.bias = 0.0\n    \n    def activate(self, inputs):\n        z = sum(w * i for w, i in zip(self.weights, inputs)) + self.bias\n        return 1.0 / (1.0 + math.exp(-z))"
        },
        {
          "id": "p2",
          "type": "code",
          "title": "The Layer",
          "xp": 4000,
          "filename": "layer.py",
          "description": "Orchestrate a layer of neurons.",
          "starter_code": "from neuron import Neuron\n\nclass Layer:\n    def __init__(self, n_neurons, n_inputs):\n        self.neurons = [Neuron(n_inputs) for _ in range(n_neurons)]\n"
        }
      ]
    },

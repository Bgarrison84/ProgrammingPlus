{
  "name": "programmingplus",
  "version": "1.0.0",
  "description": "**Offline-first, project-driven gamified app for learning multiple programming languages**",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "rebuild": "electron-rebuild",
    "dist": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.pixelforge.programmingplus",
    "productName": "Programming Plus",
    "copyright": "Copyright © 2026 Pixel Forge Studio",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "mac": {
      "target": "dmg"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "adm-zip": "^0.5.16",
    "electron": "^34.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  }
}
